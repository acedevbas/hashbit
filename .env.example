# Required: database password for the internal Postgres container.
# Generate: openssl rand -hex 16
POSTGRES_PASSWORD=change-me-please

# Required: API auth token (Bearer). Generate: openssl rand -hex 32
API_TOKEN=change-me-please-use-openssl-rand-hex-32

# Optional: Kinozal personal passkey. Without it, kinozal worker is disabled.
# Find this in the announce URL of any .torrent you download while logged in:
#   http://tr1.torrent4me.com/ann?uk=THIS_VALUE
KINOZAL_UK=
